# ÆON MAX Bot — пример окружения. Копируй в .env (который в .gitignore).

# MAX Bot API
MAX_BOT_TOKEN=
MAX_WEBHOOK_SECRET=
# Публичный URL вебхука (https). Регистрация в MAX: npm run max:subscribe
MAX_WEBHOOK_PUBLIC_URL=
# База HTTP API (по умолчанию прод MAX)
MAX_API_BASE_URL=https://platform-api.max.ru

# Диалог iter-2 (опционально; иначе дефолты в config.ts)
# FIRST_CORE_QUESTION_TEXT=
# DIALOG_ANSWER_ACK_TEXT=
# Текст сообщения только с кнопкой «Продолжить» перед каждым протокольным вопросом (iter-4)
# DIALOG_PROTOCOL_CONTINUE_GATE_MARKDOWN=
# Подсказка, если пользователь пишет текст до нажатия «Продолжить»
# DIALOG_AWAIT_CONTINUE_HINT_TEXT=

# Anthropic (основной LLM, iter-3+)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (fallback текста при ошибке Claude; DALL·E для глифа — позже)
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=

# LLM (iter-3): таймаут мс, число вопросов после legacy core:first (по умолчанию 5)
# LLM_TIMEOUT_MS=45000
# LLM_FOLLOWUP_COUNT=5
# DIALOG_LLM_NEXT_QUESTION=false

# Cognitive Identity Map iter-4 (протокол v1)
# COGNITIVE_PROTOCOL_VERSION=v1
# CARD_CONFIDENCE_THRESHOLD=0.5
# CARD_CONFIDENCE_STRONG_THRESHOLD=0.75
# CARD_RENDER_ENABLED=true   # false — только короткая строка после карты
# CARD_RENDER_TIMEOUT_MS=    # по умолчанию как LLM_TIMEOUT_MS

# PostgreSQL (локально без Docker — свой порт; с docker compose см. postgres ports в docker-compose.yml, сейчас хост :5433)
DATABASE_URL=postgres://user:pass@localhost:5432/aeon
# Интеграционные тесты: отдельная БД (TRUNCATE events). Создать: npm run test:db:prepare
TEST_DATABASE_URL=postgres://user:pass@127.0.0.1:5433/aeon_test
# Сброс событий вручную: npm run db:clear (DATABASE_URL) или npm run db:clear:test (TEST_DATABASE_URL)

# Наблюдаемость
OTEL_EXPORTER_OTLP_ENDPOINT=
# Уровень pino/Fastify: info — только общие строки запросов (≈30); debug — ещё max.webhook.* и dialog.* (протокол, LLM, карта). Обязательно загружай .env: npm run dev или node --env-file=.env dist/server.js
LOG_LEVEL=info
