# ÆON MAX Bot — пример окружения. Копируй в .env (который в .gitignore).

# MAX Bot API
MAX_BOT_TOKEN=
MAX_WEBHOOK_SECRET=
# Публичный URL вебхука (https). Регистрация в MAX: npm run max:subscribe
MAX_WEBHOOK_PUBLIC_URL=
# База HTTP API (по умолчанию прод MAX)
MAX_API_BASE_URL=https://platform-api.max.ru

# Диалог iter-2 (опционально; иначе дефолты в config.ts)
# FIRST_CORE_QUESTION_TEXT=
# DIALOG_ANSWER_ACK_TEXT=

# Anthropic (основной LLM, iter-3+)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (fallback текста при ошибке Claude; DALL·E для глифа — позже)
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=

# LLM (iter-3): таймаут мс, число вопросов после core:first (по умолчанию 5)
# LLM_TIMEOUT_MS=45000
# LLM_FOLLOWUP_COUNT=5

# PostgreSQL (локально без Docker — свой порт; с docker compose см. postgres ports в docker-compose.yml, сейчас хост :5433)
DATABASE_URL=postgres://user:pass@localhost:5432/aeon
# Интеграционные тесты: отдельная БД (TRUNCATE events). Создать: npm run test:db:prepare
TEST_DATABASE_URL=postgres://user:pass@127.0.0.1:5433/aeon_test
# Сброс событий вручную: npm run db:clear (DATABASE_URL) или npm run db:clear:test (TEST_DATABASE_URL)

# Наблюдаемость
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info
