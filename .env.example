# ÆON MAX Bot — пример окружения. Копируй в .env (который в .gitignore).

# MAX Bot API
MAX_BOT_TOKEN=
MAX_WEBHOOK_SECRET=
MAX_WEBHOOK_PUBLIC_URL=

# Anthropic (основной LLM)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (fallback для текста + DALL·E для глифа)
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=
OPENAI_IMAGE_MODEL=

# PostgreSQL
DATABASE_URL=postgres://user:pass@localhost:5432/aeon

# Redis
REDIS_URL=redis://localhost:6379

# Наблюдаемость
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info
